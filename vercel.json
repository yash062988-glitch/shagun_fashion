{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/items",
      "destination": "/index.html"
    },
    {
      "source": "/items/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|public/|about/|contact/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}